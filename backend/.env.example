# ALTHEA backend environment template
ALTHEA_ENV=development
ALTHEA_DEFAULT_TENANT_ID=default-bank
ALTHEA_TENANT_HEADER=X-Tenant-ID
ALTHEA_DATABASE_URL=postgresql+psycopg://althea:<password>@localhost:5432/althea
ALTHEA_REDIS_URL=redis://localhost:6379/0
ALTHEA_QUEUE_MODE=rq
ALTHEA_RQ_QUEUE=althea-pipeline
ALTHEA_JWT_SECRET=replace-with-a-long-random-secret
ALTHEA_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALTHEA_ALLOWED_HOSTS=localhost,127.0.0.1
ALTHEA_CORS_ALLOW_CREDENTIALS=true
ALTHEA_TRUST_PROXY_HEADERS=false
ALTHEA_REFRESH_COOKIE_NAME=althea_rt
ALTHEA_REFRESH_COOKIE_PATH=/api/auth
ALTHEA_REFRESH_COOKIE_SAMESITE=strict
ALTHEA_REFRESH_COOKIE_SECURE=false
ALTHEA_ALLOW_REFRESH_TOKEN_IN_BODY=true
ALTHEA_EXPOSE_REFRESH_TOKEN_IN_RESPONSE=true
ALTHEA_ENABLE_PUBLIC_TENANT_BOOTSTRAP=false
ALTHEA_BOOTSTRAP_PROVISIONING_SECRET=replace-with-long-random-bootstrap-secret
ALTHEA_STREAMING_INLINE_PROCESSING=false
ALTHEA_ENABLE_ALERT_JSONL_INGESTION=true
ALTHEA_ENABLE_LEGACY_INGESTION=false
ALTHEA_ENABLE_IBM_AMLSIM_IMPORT=false
ALTHEA_ENABLE_HUMAN_INTERPRETATION=true
ALTHEA_STRICT_INGESTION_VALIDATION=false
ALTHEA_ALERT_JSONL_MAX_UPLOAD_ROWS=1000
ALTHEA_INGESTION_MAX_UPLOAD_BYTES=10485760
ALTHEA_PRIMARY_INGESTION_MODE=alert_jsonl
