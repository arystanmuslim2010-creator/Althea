# ALTHEA backend environment template
ALTHEA_ENV=development
ALTHEA_DEFAULT_TENANT_ID=default-bank
ALTHEA_TENANT_HEADER=X-Tenant-ID
ALTHEA_DATABASE_URL=postgresql+psycopg://althea:<password>@localhost:5432/althea
ALTHEA_REDIS_URL=redis://localhost:6379/0
ALTHEA_QUEUE_MODE=rq
ALTHEA_RQ_QUEUE=althea-pipeline
ALTHEA_JWT_SECRET=replace-with-a-long-random-secret
ALTHEA_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALTHEA_STREAMING_INLINE_PROCESSING=false
